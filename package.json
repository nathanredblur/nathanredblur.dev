{
  "name": "nathanredblur-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "generate-resume": "tsx --tsconfig scripts/tsconfig.json scripts/generate-resume.ts",
    "build": "pnpm generate-resume && astro build && pagefind --site dist/client",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc --noEmit --isolatedDeclarations",
    "new-post": "node scripts/new-post.js",
    "optimize-images": "bash scripts/optimize-images.sh",
    "format": "biome format --write ./src ./scripts",
    "lint": "biome check --write ./src ./scripts",
    "preinstall": "npx only-allow pnpm",
    "cloudflare:preview": "wrangler dev",
    "cloudflare:deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "8.1.0",
    "@expressive-code/core": "^0.41.7",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.60",
    "@iconify/svelte": "^4.2.0",
    "@swup/astro": "^1.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "6.2.1",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "hastscript": "^9.0.1",
    "katex": "^0.16.37",
    "markdown-it": "^14.1.1",
    "mdast-util-to-string": "^4.0.0",
    "overlayscrollbars": "^2.14.0",
    "pagefind": "^1.4.0",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-github-admonitions-to-directives": "^1.0.5",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "stylus": "^0.64.0",
    "svelte": "^5.53.9",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.7",
    "@biomejs/biome": "2.4.6",
    "@react-pdf/renderer": "^4",
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/hast": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/react": "^18",
    "@types/sanitize-html": "^2.16.1",
    "react": "^18",
    "react-dom": "^18",
    "tsx": "^4",
    "wrangler": "^4.87.0"
  },
  "packageManager": "pnpm@9.14.4"
}